{
  "name": "votacao-zk-circuits",
  "version": "1.0.0",
  "description": "Circuitos ZK-SNARK para sistema de votação eletrônica",
  "scripts": {
    "compile": "./scripts/01_compile.sh",
    "setup": "./scripts/02_setup.sh",
    "export-verifier": "./scripts/03_export_verifier.sh",
    "download-ptau": "./scripts/download_ptau.sh",
    "lint": "./scripts/run_circomspect.sh",
    "inspect": "./scripts/inspect_r1cs.sh",
    "test": "mocha test/*.test.js --timeout 120000",
    "test:witness": "mocha test/*.test.js --timeout 60000",
    "test:demo": "node scripts/04_test_proof.js",
    "test:all": "./scripts/run_tests.sh --full",
    "build": "npm run compile && npm run setup",
    "build:all": "npm run compile && npm run setup && npm run export-verifier",
    "ci:lint": "./scripts/run_circomspect.sh",
    "ci:test": "./scripts/run_tests.sh --full"
  },
  "dependencies": {
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "ffjavascript": "^0.2.63",
    "snarkjs": "0.7.4"
  },
  "devDependencies": {
    "chai": "^4.3.7",
    "circom_tester": "^0.0.24",
    "mocha": "^10.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "zk-snarks",
    "circom",
    "plonk",
    "voting",
    "blockchain",
    "poseidon",
    "merkle-tree",
    "brasil"
  ],
  "license": "MIT"
}
